# Figma Project ID (CMS Resource ID)
FIGMA_PROJECT_ID=

# Environment name (e.g., production, staging)
FIGMA_ENVIRONMENT_NAME=production

# Anthropic API key — required for live compilation (Figma AI)
ANTHROPIC_API_KEY=

# Optional: override default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6
